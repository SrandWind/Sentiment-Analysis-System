          <mxGeometry x="0" y="120" width="1920" height="6" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="  02. 研究目标" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1920" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="goal1" value="核心目标\n\n基于Qwen3-8B大语言模型，\n构建支持Chain-of-Thought推理的\n中文多模态情感分析系统" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#1F497D;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="400" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="goal2" value="功能指标\n\n• 主情感分类（6类）\n• VAD情感评分\n• MBTI人格推断\n• CoT推理链可视化\n• 多模式推理支持" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#1F497D;align=center;verticalAlign=middle;fontSize=18;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="560" y="200" width="400" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="goal3" value="技术指标\n\n• 准确率 &gt; 80%\n• F1 Score &gt; 0.75\n• AUC-ROC &gt; 0.90\n• Emotion MAE &lt; 0.10\n• 推理延迟 &lt; 500ms" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#1F497D;align=center;verticalAlign=middle;fontSize=18;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1020" y="200" width="400" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="goal4" value="部署指标\n\n• 支持本地LM Studio部署\n• 支持云端vLLM部署\n• GGUF 4bit量化压缩\n• Web界面可视化展示" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#1F497D;align=center;verticalAlign=middle;fontSize=18;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1480" y="200" width="400" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="highlight" value="创新点：7步Chain-of-Thought推理链 + 红线规则防幻觉" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#C9A84C;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="1720" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="botline" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="1040" width="1920" height="4" as="geometry"/>
        </mxCell>
        <mxCell id="date" value="2026年4月" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=14;fontColor=#4A5568;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1044" width="280" height="36" as="geometry"/>
