        <mxCell id="topbar" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1F497D;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1920" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="goldline" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="120" width="1920" height="6" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="  03. 相关工作" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1920" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="header1" value="传统方法" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#C9A84C;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="180" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="content1" value="• SVM、朴素贝叶斯等机器学习模型\n• 依赖手工特征工程\n• 难以捕捉深层语义信息\n• 情感词典方法受限于词典覆盖" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="230" width="400" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="header2" value="深度学习方法" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#C9A84C;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="560" y="180" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="content2" value="• BERT、RoBERTa等预训练模型\n• TextCNN、LSTM等序列模型\n• 需要大量标注数据微调\n• 缺乏可解释性" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="560" y="230" width="400" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="header3" value="大语言模型方法" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#C9A84C;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1020" y="180" width="800" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="content3" value="• GPT-4、Claude等通用LLM\n• 强大的零样本/少样本能力\n• 支持Chain-of-Thought推理\n• API调用成本高、隐私风险" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1020" y="230" width="800" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="gap_header" value="现有方法的不足" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#C0504D;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="500" width="1720" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="gap1" value="❌ 仅返回单一情绪标签\n缺乏多维度情感评估" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="570" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="gap2" value="❌ 缺乏可解释性\n推理过程不可见" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="560" y="570" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="gap3" value="❌ 无法推断用户人格\n缺乏个性化理解" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1020" y="570" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="gap4" value="❌ 云端API依赖\n隐私与成本问题" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1480" y="570" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="botline" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="1040" width="1920" height="4" as="geometry"/>
        </mxCell>
        <mxCell id="date" value="2026年4月" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=14;fontColor=#4A5568;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1600" y="1044" width="280" height="36" as="geometry"/>
        </mxCell>
      </root>
