        <mxCell id="title" value="  06. Chain-of-Thought推理过程" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1920" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="input" value="输入文本：\n&quot;今天面试失败了，感觉自己一无是处...&quot;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#F7F8FA;align=left;verticalAlign=middle;fontSize=16;fontColor=#1A1A2E;fontFamily=微软雅黑;strokeWidth=2;strokeColor=#1F497D;" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="Step 1: 提取显式情感\n&quot;面试失败&quot; → 负面信号\n&quot;一无是处&quot; → 自我否定" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#E3F2FD;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="300" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="Step 2: 识别隐式情感\n• 叹气/无奈语气（隐含）\n• 自我评价偏低（隐含）" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#E8F5E9;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="Step 3: 确定情感强度\n悲伤强度：高 (0.85)\n焦虑程度：中 (0.60)" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#FFF3E0;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1020" y="300" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="step4" value="Step 4: 识别情感原因\n• 面试挫折\n• 自我价值怀疑" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#FCE4EC;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1480" y="300" width="400" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="step5" value="Step 5: 主情感判断\n主情感：悲伤 (sad)\n置信度：0.92" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#E1F5FE;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="100" y="460" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="step6" value="Step 6: MBTI推断\n可能类型：INFP/ISFP\n（内倾、情感型）" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#F3E5F5;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="560" y="460" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="step7" value="Step 7: 最终总结\n该用户在经历挫折后产生\n自我否定情绪，需要鼓励" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#E0F7FA;align=left;verticalAlign=top;fontSize=14;fontColor=#1A1A2E;fontFamily=微软雅黑;" vertex="1" parent="1">
          <mxGeometry x="1020" y="460" width="400" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="result" value="输出结果：\n• 主情感：悲伤 (sad)\n• 情感分数：sad=0.85, angry=0.05, neutral=0.10\n• VAD: V=-0.6, A=0.4, D=0.3\n• MBTI: INFP\n• 建议：给予鼓励和肯定" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#1F497D;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" vertex="1" parent="1">
